// =============================================
// Custom styles for Arknights theme
// =============================================

// Footer credit: 三行垂直排列，水平居中
.footer-credit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  margin-top: auto;
  padding-top: 16px;

  .footer-line {
    // mornikar / の / OpenClaw... 各占一行
  }

  a {
    text-decoration: none;
    color: #22bbff;
    font-family: BenderLight, sans-serif;
    font-size: 24px;
    padding: 6px 0;
    border-radius: 3px;
    text-align: center;
    display: block;
    width: 100%;
    &:hover {
      color: #fff;
      background: #22bbff;
    }
  }

  span {
    color: var(--text-color);
    font-family: BenderLight, sans-serif;
    font-size: 24px;
  }
}

// Post-info: 对齐到 sidebar 右边
#post-title {
  position: relative;
}

#post-info {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}
