// 自定义样式 - footer-credit 链接样式
.footer-credit {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: center;
  text-align: center;

  .footer-line {
    text-align: center;
    width: 100%;

    a {
      font-family: BenderLight, sans-serif;
      font-size: 24px;
      color: #22bbff;
      text-decoration: none;
      padding: 6px 0;
      display: inline-block;

      &:hover {
        color: #fff;
        background: #22bbff;
      }
    }

    span {
      font-size: 24px;
    }
  }
}
