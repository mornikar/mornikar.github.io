// =============================================
// Custom styles for Arknights theme
// =============================================

// FooterCreditWrapper: 撑满剩余空间，向下对齐
.footer-credit-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  flex: 1;
  width: 100%;
}

// FooterCredit: 水平居中，内容垂直排列
.footer-credit {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.8;

  .footer-title {
    display: flex;
    align-items: center;
    font-size: 0; // 消除inline-block空格
    a {
      font-size: $font-size;
      color: var(--link-color);
      &:hover {
        color: var(--text-color);
        text-decoration: underline;
      }
    }

  }

  .footer-sub {
    font-size: 0.85em;
    color: var(--text-lighten);
    opacity: 0.65;
  }
}
