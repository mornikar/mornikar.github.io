// =============================================
// Custom styles for Arknights theme
// =============================================

// Footer credit: 三行垂直排列，水平居中
.footer-credit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  margin-top: auto;
  padding-top: 16px;

  .footer-line {
    // mornikar / の / OpenClaw... 各占一行
  }

  a {
    text-decoration: none;
    color: #fff;
    background: #4a90e2;
    padding: 2px 8px;
    border-radius: 3px;
    line-height: 1.6;
    word-break: keep-all;
    &:hover {
      color: #4a90e2;
      background: #fff;
      outline: 1px solid #4a90e2;
    }
  }

  span {
    color: var(--text-color);
  }
}

// Post-info: 对齐到 sidebar 右边
#post-title {
  position: relative;
}

#post-info {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}
