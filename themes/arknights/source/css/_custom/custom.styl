// =============================================
// Custom styles for Arknights theme
// =============================================

// Footer credit: 三行垂直排列，水平居中
.footer-credit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  margin-top: auto;
  padding-top: 16px;

  .footer-line {
    // mornikar / の / OpenClaw... 各占一行
  }

  a {
    text-decoration: none;
    color: var(--link-color);
    &:hover {
      color: var(--text-color);
    }
  }

  span {
    color: var(--text-color);
  }
}
