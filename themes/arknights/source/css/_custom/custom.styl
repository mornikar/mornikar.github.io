// 自定义样式 - footer-credit 链接样式
.footer-credit {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: center;

  .footer-line {
    text-align: center;
    width: 100%;

    a {
      font-family: BenderLight, sans-serif;
      font-size: 23px;
      color: #22bbff;
      text-decoration: none;
      padding: 6px 0;
      position: relative;
      display: inline-block;

      span {
        display: block;
        line-height: 39px;
        height: 39px;
        white-space: nowrap;
      }

      // hover 时整个链接块蓝底白字
      &:hover {
        color: #fff;
        background: #22bbff;
      }
    }

    span {
      font-size: 23px;
    }
  }
}
