// =============================================
// Custom styles for Arknights theme
// =============================================

// Footer credit: 水平居中，margin-top:auto 推到 #aside-block 最底部
.footer-credit {
  text-align: center;
  margin-top: auto;
  padding-top: 16px;

  a {
    text-decoration: underline;
    &:hover {
      text-decoration: none;
      color: var(--text-color);
    }
  }

  .footer-sub {
    font-size: 0.85em;
    color: var(--text-lighten);
    opacity: 0.65;
  }
}
