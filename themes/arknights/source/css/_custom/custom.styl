// =============================================
// Custom styles for Arknights theme
// =============================================

// Footer credit: 三行垂直排列，水平居中
.footer-credit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  margin-top: auto;
  padding-top: 16px;

  .footer-line {
    // mornikar / の / OpenClaw... 各占一行
  }

  a {
    text-decoration: none !important;
    color: #fff !important;
    background: #22bbff;
    padding: 2px 8px;
    border-radius: 3px;
    line-height: 1.6;
    display: inline-block;
    text-align: center;
    min-width: 80px;
    &:hover {
      color: #22bbff !important;
      background: #fff !important;
    }
  }

  span {
    color: var(--text-color);
  }
}

// Post-info: 对齐到 sidebar 右边
#post-title {
  position: relative;
}

#post-info {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}
