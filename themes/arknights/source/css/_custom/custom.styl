// =============================================
// Custom styles for Arknights theme
// =============================================

// Footer credit: 仅调整文字对齐，不改变 footer 布局
.footer-credit {
  text-align: center;
  margin-top: 20px;
  margin-bottom: 10px;

  .footer-title {
    a {
      color: var(--link-color);
      &:hover {
        color: var(--text-color);
        text-decoration: underline;
      }
    }
  }

  .footer-sub {
    font-size: 0.85em;
    color: var(--text-lighten);
    opacity: 0.65;
  }
}
