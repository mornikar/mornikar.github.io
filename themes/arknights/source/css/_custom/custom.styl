// 自定义样式 - footer-credit 链接样式
.footer-credit {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  padding: 0 10px;

  .footer-line {
    text-align: center;
    width: 100%;
    display: flex;
    justify-content: center;

    a {
      font-family: BenderLight, sans-serif;
      font-size: 24px;
      color: #22bbff;
      text-decoration: none;
      padding: 6px 0;
      display: inline-block;
      text-align: center;
      line-height: 1.3;

      &:hover {
        color: #fff;
        background: #22bbff;
      }
    }

    span {
      font-size: 24px;
    }
  }
}
