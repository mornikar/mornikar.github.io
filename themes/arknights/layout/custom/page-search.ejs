<div id="pagefind-wrapper" style="padding: 2rem;">
  <h1 style="color: var(--theme-color); margin-bottom: 1rem;">搜索</h1>
  <link href="https://cdn.jsdelivr.net/npm/pagefind@1.1.0/pagefind-ui.css" rel="stylesheet">
  <div id="search" class="pagefind-ui"></div>
  <script src="https://cdn.jsdelivr.net/npm/pagefind@1.1.0/pagefind-ui.js" onerror="this.onerror=null; this.src='<%- url_for('/pagefind/pagefind-ui.js') %>';"></script>
  <script>
    window.addEventListener('DOMContentLoaded', (event) => {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: true,
          translations: {
            placeholder: '搜索文章...',
            zero_results: '未找到关于 "[TERMS]" 的结果',
          }
        });
      }
    });
  </script>
  <style>
    #pagefind-wrapper {
      max-width: 800px;
      margin: 0 auto;
    }
    .pagefind-ui {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: #c9a96e;
      --pagefind-ui-text: #333;
      --pagefind-ui-background: rgba(255, 255, 255, 0.9);
      --pagefind-ui-border: rgba(201, 169, 110, 0.3);
      --pagefind-ui-tag: rgba(201, 169, 110, 0.2);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 8px;
      --pagefind-ui-image-border-radius: 8px;
      --pagefind-ui-font: inherit;
    }
    .pagefind-ui__search-input {
      border: 1px solid var(--pagefind-ui-border) !important;
      border-radius: var(--pagefind-ui-border-radius) !important;
      padding: 0.75rem 1rem !important;
      font-size: 1rem !important;
    }
    .pagefind-ui__result {
      border-bottom: 1px solid var(--pagefind-ui-border) !important;
      padding: 1rem 0 !important;
    }
  </style>
</div>
