-
  // Hexo 7 兼容：通过 pug mixin 注入 helpers（pug compile 函数把 page/config 等注入为局部变量，
  // 但 is_post 等函数不会作为局部变量注入。需要从 locals.xxx 访问。
  // 解决方案：直接使用 page.xxx（pug 已注入 page），不依赖 is_post() 等裸函数。
  const _page = page || {}
  const _config = config || {}
  const _theme = theme || {}
  const _ = typeof __ === 'function' ? __ : function(k) { return k }
  let pageTitle = _page.title || _config.subtitle || ''
  if (pageTitle) pageTitle += ' | '
  pageTitle += _config.title
  const asideLogo = _theme.aside ? _theme.aside.logo : ''
  const pjax = _theme.pjax ? _theme.pjax.enable : false
  let searchConfig = null
  if (_theme.search !== undefined && _theme.search.enable === true) searchConfig = _theme.search
  const configs = JSON.stringify({
    root: _config.root || '/',
    code_fold: (_config.theme_config && _config.theme_config.post) ? _config.theme_config.post.code_fold : false,
    search: {
      preload: searchConfig ? searchConfig.preload : false,
      activeHolder: _('search.activeHolder'),
      blurHolder: _('search.blurHolder'),
      noResult: _('search.noResult')
    },
    code: {
      codeInfo: _('code.codeInfo'),
      copy: _('code.copy')
    }
  })
  let htmlThemeMode = _theme.color || 'light'
  if (_theme.color === 'dark-only') {
    htmlThemeMode = 'dark'
  } else if (_theme.color === 'light-only') {
    htmlThemeMode = 'light'
  }

doctype html
html(lang=config.language theme-mode=htmlThemeMode)
  head
    include ./meta-data.pug
  body
    if pjax
      .loading(style="opacity: 0;")
        .loadingBar.left
        .loadingBar.right
    main
      include ./header.pug
      article
        if body
          div!= body
        else
          block content
        include ./bottom-btn.pug
      include ./aside.pug
    if theme.canvas_dust
      canvas#canvas-dust

    //- Phase 6: Wiki AI 对话侧边栏
    script(defer src='https://cdn.jsdelivr.net/npm/marked@9.1.6/marked.min.js')
    script(defer src=url_for('/js/wiki-chat.js'))

    //- Phase 3.A: Wiki 目录树（在 Wiki 文章页面显示）
    script(defer src=url_for('/js/wiki-tree.js'))

    //- Phase 7: Wiki AI 登录页（仅 /login/ 页面加载）
    if _page.path && _page.path.indexOf('login') === 0
      script(src=url_for('/js/wiki-login.js'))

    //- Phase 9: InfiniteMenu 3D 球体导航（仅 /infinite-menu/ 页面加载）
    if _page.path && _page.path.indexOf('infinite-menu') === 0
      link(rel='stylesheet', href=url_for('/css/infinite-menu.css'))
      script(src=url_for('/js/infinite-menu.js') type='module')

    //- Phase 8: Wiki AI 看板娘 (Live2D)
    if theme.kanban && theme.kanban.enable
      script(defer src=url_for('/live2d/live2d.js'))

    if theme.scripts && theme.scripts.length > 0
      //- scripts list from config.yml
      each url in theme.scripts
        if url
          if url[0] === '{' && url[url.length - 1] === '}'
            script!=url
          else
            script(defer src=url)
