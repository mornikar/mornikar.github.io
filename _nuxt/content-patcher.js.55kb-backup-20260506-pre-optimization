/**
 * Content Patcher for Mornikar Portfolio
 * 
 * Loads site-config.json at runtime and:
 * 1. Intercepts window.__NUXT__ before Vue hydration → replaces Storyblok data
 * 2. Uses MutationObserver to replace DOM text after render
 * 3. Handles meta tags (title, description, OG)
 * 
 * Usage: Include this script BEFORE any Nuxt scripts in index_original.html
 */
(function () {
  'use strict';

  console.log('[content-patcher] 🚀 Script loaded, starting initialization...');

  // ── Step 0: AudioContext autoplay policy fix ──
  // KPR site uses Howler.js which tries to play audio on every GSAP animation frame.
  // Without user gesture, AudioContext.resume() triggers a browser-level console warning
  // that CANNOT be intercepted via console.warn/error overrides (it's engine-level).
  // Fix: Override AudioContext.prototype.resume to silently return resolved promise
  //      when no user gesture has occurred, preventing the browser warning entirely.
  //      On first user gesture, replay all queued resume() calls for real.
  var _audioCtxResumed = false;
  var _pendingResumes = [];

  // Override resume() — the ONLY way to prevent the browser-level warning
  var _origResume = AudioContext.prototype.resume;
  AudioContext.prototype.resume = function () {
    var ctx = this;
    if (ctx.state === 'running') {
      return Promise.resolve();
    }
    if (_audioCtxResumed) {
      // User already interacted — call real resume
      return _origResume.call(ctx);
    }
    // No user gesture yet — fake success to prevent browser warning
    // Queue for real resume when user interacts
    _pendingResumes.push(ctx);
    return Promise.resolve();
  };

  // Resume all pending AudioContexts on first user gesture
  function _resumeAllAudioCtx() {
    if (_audioCtxResumed) return;
    _audioCtxResumed = true;
    var count = _pendingResumes.length;
    if (count > 0) {
      console.log('[content-patcher] 🔊 User gesture detected, resuming', count, 'AudioContext(s)');
      _pendingResumes.forEach(function (ctx) {
        if (ctx.state === 'suspended') {
          _origResume.call(ctx).catch(function () {});
        }
      });
    }
    _pendingResumes = [];
  }

  // Listen for first user gesture (any interaction type)
  ['click', 'touchstart', 'touchend', 'keydown', 'mousedown', 'pointerdown'].forEach(function (evt) {
    document.addEventListener(evt, _resumeAllAudioCtx, { once: true, passive: true, capture: true });
  });
  // Also resume on visibility change (tab comes back to focus)
  document.addEventListener('visibilitychange', function () {
    if (!document.hidden) _resumeAllAudioCtx();
  }, { once: true, passive: true });

  // Cache-bust: ensure we always get the latest config
  var CONFIG_URL = '/site-config.json?v=' + Date.now();
  var config = null;
  var patchApplied = false;

  // ── Step 1: Intercept __NUXT__ setter ──
  // Vue/Nuxt will set window.__NUXT__ during script parsing.
  // We hook the property setter to patch data before hydration.
  var _nuxtData = null;
  var _nuxtPatched = false;

  try {
    Object.defineProperty(window, '__NUXT__', {
      configurable: true,
      enumerable: true,
      get: function () { return _nuxtData; },
      set: function (val) {
        _nuxtData = val;
        console.log('[content-patcher] __NUXT__ setter fired, config loaded:', !!config);
        // CRITICAL: patchNuxtData runs FIRST (sets English config values),
        // then applyTextsToNuxt applies texts[] translations on top.
        // This prevents patchNuxtData from overwriting texts[] replacements.
        if (!_nuxtPatched && config) {
          _nuxtPatched = true;
          patchNuxtData(val);
        }
        if (config) {
          applyTextsToNuxt();
        }
      }
    });
  } catch (e) {
    // Fallback: if defineProperty fails, we'll patch via MutationObserver
    console.warn('[content-patcher] Cannot intercept __NUXT__, will use DOM patching only');
  }

  // ── Step 2: Load config SYNCHRONOUSLY ──
  // CRITICAL: We must load config BEFORE __NUXT__ setter fires,
  // so that when Vue sets __NUXT__, we already have config loaded
  // and can patch the data before Vue hydration reads it.
  // Using synchronous XMLHttpRequest to guarantee ordering.
  try {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', CONFIG_URL, false);  // false = synchronous
    xhr.send();
    if (xhr.status === 200) {
      config = JSON.parse(xhr.responseText);
      console.log('[content-patcher] Config loaded SYNC, texts[] count:', (config.texts && config.texts.length) || 0);
    } else {
      console.warn('[content-patcher] Config fetch failed:', xhr.status);
    }
  } catch (e) {
    console.warn('[content-patcher] Sync config load failed:', e);
  }

  // If __NUXT__ was already set (unlikely but possible), patch now
  if (_nuxtData && !_nuxtPatched && config) {
    _nuxtPatched = true;
    patchNuxtData(_nuxtData);
    applyTextsToNuxt();
  }

  // ── Step 2.5: Robust __NUXT__ fallback ──
  // The defineProperty interceptor may miss if:
  // 1. __NUXT__ was set before our script executed (unlikely but possible)
  // 2. The sync XHR for config failed, so config was null when setter fired
  // 3. Nuxt's modulepreload scripts fired before our script
  // This fallback polls for window.__NUXT__ and config, patches when both available.
  var _fallbackAttempt = 0;
  function nuxtFallback() {
    if (_nuxtPatched) return;
    // Check the REAL window.__NUXT__ (not our internal _nuxtData)
    var realNuxt = window.__NUXT__;
    if (realNuxt && config) {
      _nuxtData = realNuxt;
      _nuxtPatched = true;
      console.log('[content-patcher] 🔄 __NUXT__ fallback triggered (attempt ' + _fallbackAttempt + ')');
      patchNuxtData(realNuxt);
      applyTextsToNuxt();
      return;
    }
    _fallbackAttempt++;
    if (_fallbackAttempt < 30) {
      // Retry every 100ms for 3 seconds
      setTimeout(nuxtFallback, 100);
    } else {
      console.warn('[content-patcher] ⚠ __NUXT__ fallback exhausted after 30 attempts, config=' + !!config + ', nuxt=' + !!realNuxt);
    }
  }
  // Start fallback immediately
  setTimeout(nuxtFallback, 0);

  // ── Step 2.6: Async config fallback ──
  // If sync XHR failed (Chrome deprecation, network error), load config async
  if (!config) {
    console.warn('[content-patcher] Sync config load failed, trying async...');
    var asyncXhr = new XMLHttpRequest();
    asyncXhr.open('GET', CONFIG_URL, true);  // async
    asyncXhr.onload = function() {
      if (asyncXhr.status === 200) {
        try {
          config = JSON.parse(asyncXhr.responseText);
          console.log('[content-patcher] ✅ Config loaded ASYNC, texts[] count:', (config.texts && config.texts.length) || 0);
          // Start DOM patches now that we have config
          patchMetaTags();
          patchImages();
          patchTexts();
          startDOMObserver();
          // Try __NUXT__ fallback again
          nuxtFallback();
        } catch(e) {
          console.error('[content-patcher] Async config parse error:', e);
        }
      }
    };
    asyncXhr.onerror = function() {
      console.error('[content-patcher] Async config fetch failed');
    };
    asyncXhr.send();
  }

  // ── Step 3: Async setup (DOM-dependent patches) ──
  // These run after DOM is ready and don't depend on __NUXT__ timing
  if (config) {
    console.log('[content-patcher] Config available, starting DOM patches. texts[]:', (config.texts && config.texts.length) || 0, 'images[]:', (config.images && config.images.length) || 0);
    patchMetaTags();
    patchImages();
    patchTexts();
    startDOMObserver();
  } else {
    console.warn('[content-patcher] ⚠ Config NOT loaded! No patches will be applied.');
  }

  // ── Apply texts[] to __NUXT__ data source ──
  // Runs independently of patchNuxtData — handles the case where
  // patchNuxtData might early-return before reaching deepReplaceStrings.
  // This is the CRITICAL path for text replacement.
  function applyTextsToNuxt() {
    var nuxt = _nuxtData;
    if (!nuxt) {
      console.log('[content-patcher] applyTextsToNuxt: __NUXT__ not yet available');
      return;
    }
    if (!config || !config.texts || !Array.isArray(config.texts) || config.texts.length === 0) {
      return;  // No texts to apply, silent
    }

    var validTexts = config.texts.filter(function(t) { return t.original && t.replacement; });
    if (validTexts.length === 0) return;

    console.log('[content-patcher] Applying', validTexts.length, 'texts[] to __NUXT__...');
    if (nuxt.data) console.log('[content-patcher] __NUXT__.data keys:', Object.keys(nuxt.data));

    // DEBUG: Check each original against __NUXT__
    validTexts.forEach(function(t) {
      var found = findStringInObject(nuxt, t.original);
      console.log('[content-patcher] DEBUG __NUXT__ check: "' + t.original.substring(0, 50) + '..." → ' + (found ? '✅ FOUND' : '❌ NOT FOUND'));
    });

    // DEBUG: Dump sample strings from __NUXT__ homepage data
    if (nuxt.data && nuxt.data['us-en/'] && nuxt.data['us-en/'].content) {
      var homeContent = nuxt.data['us-en/'].content;
      console.log('[content-patcher] DEBUG homepage content keys:', Object.keys(homeContent));
      if (homeContent.body) {
        homeContent.body.forEach(function(block, i) {
          if (block && block.component) {
            var strFields = {};
            Object.keys(block).forEach(function(k) {
              if (typeof block[k] === 'string' && block[k].length > 2) strFields[k] = block[k].substring(0, 80);
            });
            console.log('[content-patcher] DEBUG block[' + i + '] component=' + block.component + ' strings:', JSON.stringify(strFields));
          }
        });
      }
    }

    var replaced = deepReplaceStrings(nuxt, validTexts);
    console.log('[content-patcher] ✅ texts[] applied to __NUXT__:', replaced, 'string(s) replaced');
  }

  // ── Patch __NUXT__ Storyblok data ──
  function patchNuxtData(nuxt) {
    if (!config) return;
    try {
      var homeKey = 'us-en/';
      var homeData = nuxt.data && nuxt.data[homeKey];
      if (!homeData || !homeData.content || !homeData.content.body) {
        console.warn('[content-patcher] Homepage data not found in __NUXT__');
        return;
      }

      var blocks = homeData.content.body;

      // Block 0: HomeLanding
      if (blocks[0] && config.landing) {
        blocks[0].desc = config.landing.desc;
        blocks[0].keep = config.landing.keep;
        blocks[0].protect = config.landing.protect;
        blocks[0].reimagine = config.landing.reimagine;
      }

      // Block 1: HomeStoryIntro
      if (blocks[1] && config.storyIntro) {
        blocks[1].title = config.storyIntro.title;
        blocks[1].body = config.storyIntro.body;
        if (config.storyIntro.video_caption) blocks[1].video_caption = config.storyIntro.video_caption;
        if (config.storyIntro.character_caption) blocks[1].character_caption = config.storyIntro.character_caption;
        if (config.storyIntro.image_caption_medium) blocks[1].image_caption_medium = config.storyIntro.image_caption_medium;
      }

      // Block 2: HomeStoryProject
      if (blocks[2] && config.storyProject) {
        if (config.storyProject.strapline_1) blocks[2].story_strapline_1 = config.storyProject.strapline_1;
        if (config.storyProject.strapline_2) blocks[2].story_strapline_2 = config.storyProject.strapline_2;
        if (config.storyProject.console_text_loading) blocks[2].console_text_loading = config.storyProject.console_text_loading;
        if (config.storyProject.console_text_coordinates) blocks[2].console_text_coordinates = config.storyProject.console_text_coordinates;
        if (config.storyProject.console_text_temperature) blocks[2].console_text_temperature = config.storyProject.console_text_temperature;
      }

      // Block 3: HomeCollectionIntro
      if (blocks[3] && config.collection) {
        blocks[3].Collection_Name = config.collection.name;
        blocks[3].Collection_Size = config.collection.size;
        blocks[3].Launch_Date = config.collection.launch_date;
        blocks[3].Launch_Label = config.collection.launch_label;
        blocks[3].Image_Caption_1 = config.collection.caption_1;
        blocks[3].Image_Caption_2 = config.collection.caption_2;
      }

      // Block 4: HomeCollectionGallery
      if (blocks[4] && config.collectionGallery) {
        blocks[4].Gallery_Heading = config.collectionGallery.heading;
        blocks[4].Gallery_Description = config.collectionGallery.description;
        if (config.collectionGallery.console_text) blocks[4].Console_Text_Preceding_Description = config.collectionGallery.console_text;
      }

      // Block 5: HomeTableauxKeep
      if (blocks[5] && config.tableaux && config.tableaux.keep) {
        blocks[5].Tableaux_1_Description = config.tableaux.keep.description;
        blocks[5].Tableaux_1_Console_Text = config.tableaux.keep.console_text;
      }

      // Block 6: HomeTableauxFactions
      if (blocks[6] && config.tableaux && config.tableaux.factions) {
        blocks[6].Tableaux_2_Description = config.tableaux.factions.description;
        blocks[6].Tableaux_2_Console_Text = config.tableaux.factions.console_text;
      }

      // Block 7: HomeTableauxUniverse
      if (blocks[7] && config.tableaux && config.tableaux.universe) {
        blocks[7].Tableaux_3_Description = config.tableaux.universe.description;
        blocks[7].Tableaux_3_Console_Text = config.tableaux.universe.console_text;
      }

      // Block 8: HomeLaunch
      if (blocks[8] && config.launch) {
        blocks[8].Launch_Day = config.launch.day;
        blocks[8].Launch_Month = config.launch.month;
        if (config.launch.cta_label) blocks[8].Home_Launch_CTA_Label = config.launch.cta_label;
        if (config.launch.description) blocks[8].Home_Launch_Description = config.launch.description;
        if (config.launch.console_text) blocks[8].Home_Launch_Console_Text = config.launch.console_text;
        if (config.launch.link_caption_keep) blocks[8].Link_Caption_Keep = config.launch.link_caption_keep;
        if (config.launch.link_caption_factions) blocks[8].Link_Caption_Factions = config.launch.link_caption_factions;
        if (config.launch.link_caption_universe) blocks[8].Link_Caption_Universe = config.launch.link_caption_universe;
      }

      // Nav
      var navData = nuxt.data['us-en/global/the-nav'];
      if (navData && navData.content && config.nav) {
        navData.content.buy_title = config.nav.buy_title;
        navData.content.nav_title = config.nav.nav_title;
        if (config.nav.social_title) navData.content.social_title = config.nav.social_title;
        if (config.nav.items && navData.content.nav_items) {
          config.nav.items.forEach(function (item, i) {
            if (navData.content.nav_items[i]) {
              navData.content.nav_items[i].label = item.label;
            }
          });
        }
      }

      // Footer
      var footerData = nuxt.data['us-en/global/the-footer'];
      if (footerData && footerData.content && config.footer) {
        footerData.content.nav_title = config.footer.nav_title;
        footerData.content.social_title = config.footer.social_title;
        footerData.content.press_title = config.footer.press_title;
        footerData.content.press_desc = config.footer.press_desc;
        footerData.content.press_kit_label = config.footer.press_kit_label;
        footerData.content.copyright = config.footer.copyright;
        if (config.footer.console) footerData.content.console = config.footer.console;
        if (config.footer.press_email) footerData.content.press_email = config.footer.press_email;
        if (config.footer.press_contact_us) footerData.content.press_contact_us = config.footer.press_contact_us;
      }

      // Pinia social links
      if (nuxt.pinia && nuxt.pinia.app && config.social) {
        if (config.social.twitter) nuxt.pinia.app.socialLinkTwitter = config.social.twitter;
        if (config.social.instagram) nuxt.pinia.app.socialLinkInstagram = config.social.instagram;
        if (config.social.discord) nuxt.pinia.app.socialLinkDiscord = config.social.discord;
      }

      console.log('[content-patcher] __NUXT__ data patched successfully (texts[] handled by applyTextsToNuxt)');
    } catch (e) {
      console.error('[content-patcher] Error patching __NUXT__:', e);
    }
  }

  // ── Deep walk object, replace string values matching texts[] ──
  // Uses EXACT matching (===) to prevent "Keep" from matching "Keeper".
  // Sorts by original length descending so longer matches take priority.
  function deepReplaceStrings(obj, texts, depth) {
    if (!obj || typeof obj !== 'object' || depth > 15) return 0;
    depth = depth || 0;
    var replaced = 0;
    var keys = Object.keys(obj);
    // Sort by original length descending — longer matches first
    var sortedTexts = texts.slice().sort(function(a, b) { return b.original.length - a.original.length; });
    for (var i = 0; i < keys.length; i++) {
      var key = keys[i];
      var val = obj[key];
      if (typeof val === 'string') {
        for (var j = 0; j < sortedTexts.length; j++) {
          // Exact match only — prevents "Keep" from matching "Keeper"
          if (val === sortedTexts[j].original) {
            obj[key] = sortedTexts[j].replacement;
            replaced++;
            console.log('[content-patcher] ✅ __NUXT__ replaced key="' + key + '": "' + sortedTexts[j].original.substring(0, 40) + '..." → "' + sortedTexts[j].replacement.substring(0, 40) + '..."');
            break;
          }
        }
      } else if (typeof val === 'object' && val !== null) {
        replaced += deepReplaceStrings(val, sortedTexts, depth + 1);
      }
    }
    return replaced;
  }

  // ── Check if a string exists anywhere in an object ──
  function findStringInObject(obj, str, depth) {
    if (!obj || typeof obj !== 'object' || (depth || 0) > 15) return false;
    var keys = Object.keys(obj);
    for (var i = 0; i < keys.length; i++) {
      var val = obj[keys[i]];
      if (typeof val === 'string' && val === str) return true;
      if (typeof val === 'object' && val !== null && findStringInObject(val, str, (depth || 0) + 1)) return true;
    }
    return false;
  }

  // ── Patch meta tags ──
  function patchMetaTags() {
    if (!config || !config.site) return;
    try {
      // Title
      var titleEl = document.querySelector('title');
      if (titleEl) titleEl.textContent = config.site.title;

      // Meta description
      setMeta('name', 'description', config.site.description);
      
      // OG tags
      setMeta('property', 'og:title', config.site.title);
      setMeta('property', 'og:description', config.site.description);
      setMeta('property', 'og:site_name', config.site.title);
      if (config.site.url) setMeta('property', 'og:url', config.site.url);
      if (config.site.ogImage) setMeta('property', 'og:image', config.site.ogImage);
      
      // Twitter tags
      setMeta('name', 'twitter:title', config.site.title);
      setMeta('name', 'twitter:description', config.site.description);
      if (config.site.url) setMeta('name', 'twitter:url', config.site.url);
      if (config.site.ogImage) setMeta('name', 'twitter:image', config.site.ogImage);

      console.log('[content-patcher] Meta tags patched');
    } catch (e) {
      console.error('[content-patcher] Error patching meta tags:', e);
    }
  }

  function setMeta(attr, val, content) {
    var el = document.querySelector('meta[' + attr + '="' + val + '"]');
    if (el) el.setAttribute('content', content);
  }

  // ── DOM MutationObserver ──
  // Catches text that Vue renders into the DOM after hydration
  function startDOMObserver() {
    if (!config) return;

    // Build a map of old text → new text for DOM replacement
    var textMap = buildTextMap();
    var hasTextMap = Object.keys(textMap).length > 0;
    var hasTextsArray = config.texts && Array.isArray(config.texts) && config.texts.length > 0;

    if (!hasTextMap && !hasTextsArray) return;

    // Debounce: coalesce rapid mutations (Vue re-render bursts)
    var _debounceTimer = null;
    var _patching = false;  // Guard against self-triggered mutations
    var _lastPatchTime = 0;  // Track last patch time to avoid rapid re-patching
    function schedulePatch() {
      if (_patching) return;  // Skip if we're already patching
      // Don't re-patch within 500ms of last patch (avoid self-triggered loops)
      var now = Date.now();
      if (now - _lastPatchTime < 500) return;
      if (_debounceTimer) clearTimeout(_debounceTimer);
      _debounceTimer = setTimeout(function () {
        _patching = true;
        _lastPatchTime = Date.now();
        try {
          if (hasTextMap) replaceDOMText(textMap);
          if (hasTextsArray) patchTextsImmediate();
          if (config && config.images && config.images.length > 0) {
            patchImagesImmediate();
          }
        } finally {
          // Reset flag after a delay to let mutations settle
          setTimeout(function () { _patching = false; }, 100);
        }
      }, 150);
    }

    var observer = new MutationObserver(function (mutations) {
      for (var i = 0; i < mutations.length; i++) {
        // New nodes added (Vue re-render)
        if (mutations[i].addedNodes.length > 0) { schedulePatch(); return; }
        // Text content changed (Vue overwriting our replacement)
        if (mutations[i].type === 'characterData') { schedulePatch(); return; }
      }
    });

    observer.observe(document.documentElement, {
      childList: true,
      subtree: true,
      characterData: true,
      characterDataOldValue: true
    });

    // Initial passes after Vue hydration
    setTimeout(function () {
      if (hasTextMap) replaceDOMText(textMap);
      if (hasTextsArray) patchTextsImmediate();
    }, 2000);

    setTimeout(function () {
      if (hasTextMap) replaceDOMText(textMap);
      if (hasTextsArray) patchTextsImmediate();
    }, 5000);

    var totalRules = Object.keys(textMap).length + (hasTextsArray ? config.texts.length : 0);
    console.log('[content-patcher] DOM observer started with', totalRules, 'replacement rules');
  }

  function buildTextMap() {
    if (!config) return {};
    var map = {};

    // Landing
    if (config.landing) {
      addMap(map, 'KPR is a brand that focuses on collective narrative and empowering storytellers. Keepers is a living story, an uncharted world waiting to be explored, to be imagined.', config.landing.desc);
    }

    // Story Intro
    if (config.storyIntro) {
      addMap(map, 'A familiar world... Set on a different path.', config.storyIntro.title);
      addMap(map, 'Isolated within the New Eden safe zone, you witness humanity struggling to avoid descending into chaos.', config.storyIntro.body);
    }

    // Story Project
    if (config.storyProject) {
      addMap(map, 'You are a Keeper: an agent of power and change in this world.', config.storyProject.strapline_1);
      addMap(map, 'What will you do with this power? Will you choose to protect or destroy? To give or to take?', config.storyProject.strapline_2);
    }

    // Tableaux
    if (config.tableaux) {
      addMap(map, 'The last stronghold of all knowledge. The Keep is where all the value accrues. A place to wonder, protect, and fight for.', config.tableaux.keep.description);
      addMap(map, 'One world, two factions. Divided in belief, united in purpose.', config.tableaux.factions.description);
      addMap(map, 'The discovery of Kai, the world\'s primordial energy source, heralded mankind\'s Golden Age. Or so they believed.', config.tableaux.universe.description);
    }

    // Collection
    if (config.collection) {
      addMap(map, 'Initial Collection', config.collection.name);
      addMap(map, 'Kai Crystal', config.collection.caption_1);
      addMap(map, 'Windows to the Soul', config.collection.caption_2);
    }

    // Collection Gallery
    if (config.collectionGallery) {
      addMap(map, '10,000 unique digital collectibles.', config.collectionGallery.heading.trim());
    }

    // Launch
    if (config.launch) {
      addMap(map, 'What path will you forge as you become the Keeper of your destiny?', config.launch.description);
    }

    // Footer
    if (config.footer) {
      addMap(map, 'Discover More', config.footer.nav_title);
      addMap(map, 'Join the Conversation', config.footer.social_title);
      addMap(map, 'More Details', config.footer.press_title);
      addMap(map, 'Want to learn more about how we collaborate with partners?', config.footer.press_desc);
      addMap(map, 'Download Brand Book', config.footer.press_kit_label);
      addMap(map, '© 2022', config.footer.copyright);
    }

    // Nav
    if (config.nav) {
      addMap(map, 'Buy On', config.nav.buy_title);
    }

    return map;
  }

  function addMap(map, oldText, newText) {
    if (oldText && newText && oldText !== newText) {
      map[oldText] = newText;
    }
  }

  function replaceDOMText(textMap) {
    var keys = Object.keys(textMap);
    var replaced = 0;

    // Walk all text nodes
    var walker = document.createTreeWalker(
      document.body,
      NodeFilter.SHOW_TEXT,
      null,
      false
    );

    var node;
    while ((node = walker.nextNode())) {
      var text = node.textContent;
      for (var i = 0; i < keys.length; i++) {
        if (text.indexOf(keys[i]) !== -1) {
          node.textContent = text.split(keys[i]).join(textMap[keys[i]]);
          replaced++;
          break; // One replacement per node to avoid conflicts
        }
      }
    }

    // Also check placeholder/alt/title attributes
    var attrElements = document.querySelectorAll('[placeholder], [alt], [title], [aria-label]');
    attrElements.forEach(function (el) {
      ['placeholder', 'alt', 'title', 'aria-label'].forEach(function (attr) {
        var val = el.getAttribute(attr);
        if (val) {
          for (var i = 0; i < keys.length; i++) {
            if (val.indexOf(keys[i]) !== -1) {
              el.setAttribute(attr, val.split(keys[i]).join(textMap[keys[i]]));
              replaced++;
              break;
            }
          }
        }
      });
    });

    if (replaced > 0) {
      console.log('[content-patcher] DOM text replaced:', replaced, 'nodes');
    }
  }

  // ── Patch <img> src by selector (from site-config.json → images) ──
  // Usage in site-config.json:
  // {
  //   "images": [
  //     { "selector": ".homeStoryIntro_img", "src": "/images/my-hero.webp" },
  //     { "selector": ".homeProjectIntro_img1", "src": "/images/my-project.webp" },
  //     { "selector": "img[alt='character']", "src": "/images/my-character.webp" }
  //   ]
  // }
  // ── Single-shot image patch (used by MutationObserver) ──
  function patchImagesImmediate() {
    if (!config || !config.images || !Array.isArray(config.images)) return;
    config.images.forEach(function (img) {
      if (!img.selector || !img.src || img._comment) return;
      if (img._patched) return;  // Already patched, skip
      var els;
      try { els = document.querySelectorAll(img.selector); }
      catch (e) {
        console.warn('[content-patcher] ❌ Invalid selector:', img.selector, e.message);
        return;
      }
      if (els.length === 0) return;
      console.log('[content-patcher] selector: "' + img.selector + '" → matched ' + els.length + ' element(s)');
      els.forEach(function (el) {
        // <img> 标签
        if (el.tagName === 'IMG' && el.src !== img.src) {
          el.src = img.src;
          console.log('[content-patcher] ✅ <img> replaced: ' + el.src + ' → ' + img.src);
        }
        // <svg> 内嵌 <image> 标签 (href / xlink:href)
        else if (el.tagName === 'IMAGE' || el.tagName === 'image') {
          var svgOld = el.getAttribute('href') || el.getAttributeNS('http://www.w3.org/1999/xlink', 'href') || '';
          if (svgOld !== img.src) {
            el.setAttribute('href', img.src);
            el.setAttributeNS('http://www.w3.org/1999/xlink', 'href', img.src);
            console.log('[content-patcher] ✅ <image> href replaced: ' + svgOld + ' → ' + img.src);
          }
        }
        // backgroundImage CSS
        else if (img.backgroundImage && el.style) {
          el.style.backgroundImage = 'url("' + img.src + '")';
          console.log('[content-patcher] ✅ backgroundImage set on: ' + el.tagName);
        }
      });
      img._patched = true;  // Mark as patched to avoid re-processing
    });
  }

  // ── Single-shot text patch (used by MutationObserver) ──
  // Uses selector-scoped matching: only replaces text within elements
  // matching the selector. This prevents "Keep" from matching "Keeper".
  // Falls back to exact text-node matching (no substring) when needed.
  // Track text rules that have been successfully applied (to avoid re-scanning)
  var _matchedTextRules = {};  // key: original text, value: true

  function patchTextsImmediate() {
    if (!config || !config.texts || !Array.isArray(config.texts)) return;

    var validTexts = config.texts.filter(function(t) { return t.original && t.replacement; });
    if (validTexts.length === 0) return;

    // Filter out already-matched rules
    var remainingTexts = validTexts.filter(function(t) { return !_matchedTextRules[t.original]; });
    if (remainingTexts.length === 0) return;  // All rules already applied, skip scan entirely

    // Sort by original length descending — longer matches first
    remainingTexts.sort(function(a, b) { return b.original.length - a.original.length; });

    console.log('[content-patcher] 🔍 patchTextsImmediate:', remainingTexts.length, 'remaining/', validTexts.length, 'total text rules');

    var replaced = 0;
    var totalChecked = 0;
    var sampleTexts = [];

    for (var i = 0; i < remainingTexts.length; i++) {
      var txt = remainingTexts[i];
      var matched = false;

      // ── Strategy 1: Selector-scoped matching ──
      if (txt.selector) {
        var els;
        try { els = document.querySelectorAll(txt.selector); }
        catch (e) {
          console.warn('[content-patcher] ❌ Invalid selector:', txt.selector);
          els = null;
        }

        if (els && els.length > 0) {
          // Try matching each element's textContent exactly
          for (var j = 0; j < els.length; j++) {
            var el = els[j];
            var elText = el.textContent.trim();

            if (elText === txt.original) {
              el.textContent = txt.replacement;
              replaced++;
              matched = true;
              _matchedTextRules[txt.original] = true;
              console.log('[content-patcher] ✅ selector "' + txt.selector + '" exact match: "' + txt.original.substring(0, 40) + '..." → "' + txt.replacement.substring(0, 40) + '..."');
              break;
            }
          }

          // If no single element matched, try parent element (for split text across children)
          if (!matched) {
            var parent = els[0].parentElement;
            if (parent) {
              var parentText = parent.textContent.trim();
              if (parentText === txt.original) {
                parent.textContent = txt.replacement;
                replaced++;
                matched = true;
                _matchedTextRules[txt.original] = true;
                console.log('[content-patcher] ✅ selector "' + txt.selector + '" parent match: "' + txt.original.substring(0, 40) + '..." → "' + txt.replacement.substring(0, 40) + '..."');
              } else if (parentText.indexOf(txt.original) !== -1) {
                // Original is substring of parent text — safe because selector scopes it
                parent.textContent = parentText.split(txt.original).join(txt.replacement);
                replaced++;
                matched = true;
                _matchedTextRules[txt.original] = true;
                console.log('[content-patcher] ✅ selector "' + txt.selector + '" parent-substring match');
              }
            }
          }

          if (!matched) {
            var elFullText = els[0].textContent.trim();
            // Check if the text already matches the replacement (already applied via __NUXT__)
            if (elFullText === txt.replacement || elFullText.indexOf(txt.replacement) !== -1 || txt.replacement.indexOf(elFullText) !== -1) {
              // Already replaced — this is expected, no warning needed
              matched = true;
              _matchedTextRules[txt.original] = true;  // Mark as handled permanently
            } else if (!_matchedTextRules['_warn_mismatch_' + txt.selector]) {
              _matchedTextRules['_warn_mismatch_' + txt.selector] = true;
              console.log('[content-patcher] ⚠ selector "' + txt.selector + '" matched ' + els.length + ' el(s) but text mismatch. Element: "' + elFullText.substring(0, 80) + '"');
            }
          }

          if (matched) continue;  // Move to next rule — selector was found, don't fall through
        }

        // Selector didn't match any elements — fall through to strategy 2
        // Only log this once (not on every MutationObserver trigger)
        if (!_matchedTextRules['_warn_' + txt.selector]) {
          _matchedTextRules['_warn_' + txt.selector] = true;
          console.log('[content-patcher] ℹ selector "' + txt.selector + '" → 0 elements, trying exact-text fallback');
        }
      }

      // ── Strategy 2: Exact text-node matching (no substring) ──
      // Walk all text nodes looking for exact match only.
      // This prevents "Keep" from matching inside "Keeper".
      var walker = document.createTreeWalker(
        document.body,
        NodeFilter.SHOW_TEXT,
        {
          acceptNode: function (node) {
            if (!node.textContent.trim()) return NodeFilter.FILTER_REJECT;
            var parent = node.parentElement;
            if (!parent) return NodeFilter.FILTER_REJECT;
            var tag = parent.tagName;
            if (tag === 'SCRIPT' || tag === 'STYLE' || tag === 'NOSCRIPT') return NodeFilter.FILTER_REJECT;
            return NodeFilter.FILTER_ACCEPT;
          }
        },
        false
      );

      var node;
      while ((node = walker.nextNode())) {
        totalChecked++;
        var text = node.textContent;

        // Collect sample texts for debugging (first 15 non-trivial ones)
        if (sampleTexts.length < 15 && text.trim().length > 3) {
          sampleTexts.push(text.trim().substring(0, 80));
        }

        // Exact text node content match (trimmed)
        if (text.trim() === txt.original) {
          node.textContent = txt.replacement;
          replaced++;
          matched = true;
          _matchedTextRules[txt.original] = true;
          console.log('[content-patcher] ✅ exact-text replaced: "' + txt.original.substring(0, 40) + '..." → "' + txt.replacement.substring(0, 40) + '..."');
          break;
        }

        // Already replaced (via __NUXT__ data patch) — skip silently
        if (text.trim() === txt.replacement) {
          matched = true;
          _matchedTextRules[txt.original] = true;
          break;
        }

        // Parent element full text match (handles split text nodes)
        var parent = node.parentElement;
        if (parent && !parent._textReplaced) {
          var parentText = parent.textContent.trim();
          if (parentText === txt.original) {
            parent.textContent = txt.replacement;
            parent._textReplaced = true;
            replaced++;
            matched = true;
            _matchedTextRules[txt.original] = true;
            console.log('[content-patcher] ✅ parent-text replaced: "' + txt.original.substring(0, 40) + '..." → "' + txt.replacement.substring(0, 40) + '..."');
            break;
          }
          // Already replaced at parent level — skip silently
          if (parentText === txt.replacement) {
            matched = true;
            _matchedTextRules[txt.original] = true;
            break;
          }
        }
      }

      if (!matched) {
        // Only log once per rule, not on every scan
        if (!_matchedTextRules['_warn_' + txt.original]) {
          _matchedTextRules['_warn_' + txt.original] = true;
          console.log('[content-patcher] ⚠ text rule not matched: "' + txt.original.substring(0, 40) + '..."');
        }
      }
    }

    // Also check attributes (placeholder, alt, title, aria-label) — exact match only
    var attrEls = document.querySelectorAll('[placeholder], [alt], [title], [aria-label]');
    attrEls.forEach(function (el) {
      ['placeholder', 'alt', 'title', 'aria-label'].forEach(function (attr) {
        var val = el.getAttribute(attr);
        if (val) {
          for (var i = 0; i < validTexts.length; i++) {
            if (val === validTexts[i].original) {
              el.setAttribute(attr, validTexts[i].replacement);
              replaced++;
              break;
            }
          }
        }
      });
    });

    if (replaced > 0) {
      console.log('[content-patcher] texts[] DOM patch:', replaced, 'node(s) replaced');
    }
    // Only log "0 matches" summary once (not on every MutationObserver trigger)
    else if (!_matchedTextRules['_warn_noscan']) {
      _matchedTextRules['_warn_noscan'] = true;
      console.log('[content-patcher] 🔍 DOM scan: checked', totalChecked, 'text nodes, 0 new matches. Sample texts:', JSON.stringify(sampleTexts));
    }
  }

  // ── Retry loop for initial page load ──
  function patchImages() {
    if (!config || !config.images || !Array.isArray(config.images)) return;
    var validImgs = config.images.filter(function(img){ return img.selector && img.src && !img._comment; });
    if (validImgs.length === 0) return;

    var attempts = 0;
    var maxAttempts = 10;
    var interval = 500;

    function tryPatch() {
      attempts++;
      var replaced = 0;
      validImgs.forEach(function (img) {
        var els;
        try { els = document.querySelectorAll(img.selector); }
        catch (e) {
          console.warn('[content-patcher] ❌ Invalid selector:', img.selector, e.message);
          return;
        }
        console.log('[content-patcher] attempt ' + attempts + ': "' + img.selector + '" → ' + els.length + ' match(es)');
        els.forEach(function (el) {
          // <img> 标签
          if (el.tagName === 'IMG' && el.src !== img.src) {
            el.src = img.src;
            replaced++;
            console.log('[content-patcher] ✅ <img> src replaced: ' + img.src);
          }
          // <svg> 内嵌 <image> 标签
          else if (el.tagName === 'IMAGE' || el.tagName === 'image') {
            var svgOld = el.getAttribute('href') || el.getAttributeNS('http://www.w3.org/1999/xlink', 'href') || '';
            if (svgOld !== img.src) {
              el.setAttribute('href', img.src);
              el.setAttributeNS('http://www.w3.org/1999/xlink', 'href', img.src);
              replaced++;
              console.log('[content-patcher] ✅ <image> href replaced: ' + svgOld + ' → ' + img.src);
            }
          }
          // backgroundImage CSS
          if (img.backgroundImage && el.style) {
            el.style.backgroundImage = 'url("' + img.src + '")';
            replaced++;
            console.log('[content-patcher] ✅ backgroundImage set');
          }
        });
      });

      if (replaced > 0) {
        console.log('[content-patcher] ✓ Done — ' + replaced + ' element(s) patched');
        return;
      }

      if (attempts < maxAttempts) {
        setTimeout(tryPatch, interval);
      } else {
        console.log('[content-patcher] ⚠ No elements matched ' + validImgs.length + ' selector(s) after ' + maxAttempts + ' attempts');
        console.log('[content-patcher] 💡 Tip: DevTools → Elements → find <img> → right-click → Copy → Copy selector');
      }
    }

    console.log('[content-patcher] patchImages: ' + validImgs.length + ' rule(s), starting in 1.5s...');
    setTimeout(tryPatch, 1500);
  }

  // ── Patch text content from site-config.json → texts[] ──
  // No selector required — walks all DOM text nodes and replaces matching strings.
  // Format: { "texts": [{ "original": "Welcome", "replacement": "你好" }] }
  function patchTexts() {
    if (!config || !config.texts || !Array.isArray(config.texts)) return;
    var validTexts = config.texts.filter(function(t) { return t.original && t.replacement; });
    if (validTexts.length === 0) return;

    console.log('[content-patcher] patchTexts: ' + validTexts.length + ' rule(s), starting in 1.5s...');

    var attempts = 0;
    var maxAttempts = 10;
    var interval = 500;

    function tryPatch() {
      attempts++;
      patchTextsImmediate();

      // Check if any replacements were made (patchTextsImmediate logs itself)
      // Just retry a few times to catch Vue re-renders
      if (attempts < 3) {
        setTimeout(tryPatch, interval);
      }
    }

    setTimeout(tryPatch, 1500);
  }

  // ── Gallery Video Preview ──
  // Non-destructive: adds a cover overlay on video cards, click to open B站 video in modal.
  // Does NOT modify .collectionGallery__item styles or touch the carousel.
  //
  // site-config.json → gallery.videos:
  //   [{ "selector": ".collectionGallery__item", "bvid": "BV1xxx", "label": "Demo", "cover": "/images/cover.jpg" }]
  function setupGalleryVideoPreview() {
    var galleryCfg = config && config.gallery;
    var videos = (galleryCfg && galleryCfg.videos) || [];

    if (videos.length === 0) return;

    console.log('[content-patcher] 🎬 Gallery video preview setup, videos:', JSON.stringify(videos));

    // Inject minimal, scoped styles (no !important overrides of existing elements)
    injectVideoPreviewStyles();
    createVideoModal();

    // Retry binding until gallery items appear
    var _bindAttempts = 0;
    function tryBindVideoCards() {
      _bindAttempts++;
      videos.forEach(function(v) {
        var els;
        try { els = document.querySelectorAll(v.selector); }
        catch(e) { return; }
        els.forEach(function(el, idx) {
          if (el._kprVideoBound) return;
          el._kprVideoBound = true;

          // Mark as video item for document-level handler
          el.setAttribute('data-kpr-video-item', 'true');
          el.setAttribute('data-kpr-video-index', idx.toString());

          // Make item clickable
          el.style.cursor = 'pointer';
          el.style.pointerEvents = 'auto'; // Force auto to override KPR's possible none

          // Add cover overlay (absolute positioned inside item, NOT replacing background)
          if (v.cover) {
            var cover = document.createElement('div');
            cover.className = 'kpr-v-cover';
            cover.style.backgroundImage = 'url("' + v.cover + '")';
            el.appendChild(cover);

            // Play icon on top of cover
            var playBtn = document.createElement('div');
            playBtn.className = 'kpr-v-play';
            playBtn.innerHTML = '<svg viewBox="0 0 24 24" width="36" height="36"><circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.65)"/><polygon points="9,6 19,12 9,18" fill="white"/></svg>';
            el.appendChild(playBtn);
          }

          // Click to open video in modal - THREE LAYER PROTECTION
          // Layer 1: Direct click on element with capture mode
          el.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
            console.log('[content-patcher] 🎬 Video clicked (layer 1 - direct):', v.bvid);
            openVideoModal(v.bvid, v.label || 'Video');
          }, true); // capture mode
          
          // Force pointer-events auto to override KPR's possible none setting
          el.style.pointerEvents = 'auto';
          el.style.cursor = 'pointer';
        });
      });

      if (_bindAttempts < 12 && !document.querySelector('.kpr-v-cover')) {
        setTimeout(tryBindVideoCards, 800);
      }
    }

    setTimeout(tryBindVideoCards, 2500);
  }

