  function createVideoModal() {
    if (document.getElementById('kpr-v-modal')) return;
    // 【修复2026-05-05】等待document.body就绪后再appendChild，避免脚本在<head>中执行时body为null
    if (!document.body) {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', createVideoModal);
      } else {
        setTimeout(createVideoModal, 50);
      }
      return;
    }
    var m = document.createElement('div');
    m.className = 'kpr-v-modal';
    m.id = 'kpr-v-modal';
    m.innerHTML = '<div class="kpr-v-modal__box">' +
      '<div class="kpr-v-modal__close" id="kpr-v-close">&times;</div>' +
      '<div class="kpr-v-modal__title" id="kpr-v-title">Video</div>' +
      '<iframe id="kpr-v-iframe" allowfullscreen="true" scrolling="no"></iframe>' +
      '</div>';
    document.body.appendChild(m);

    document.getElementById('kpr-v-close').addEventListener('click', closeVideoModal);
    m.addEventListener('click', function(e) { if (e.target === m) closeVideoModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeVideoModal(); });
  }

  function openVideoModal(bvid, label) {
    var m = document.getElementById('kpr-v-modal');
    var iframe = document.getElementById('kpr-v-iframe');
    var title = document.getElementById('kpr-v-title');

    // Strategy: try iframe first, fallback to direct navigation if blocked
    if (m && iframe) {
      if (title) title.textContent = label || bvid;
      
      // B站 embed URL — isOutside=true bypasses X-Frame-Options on some configs
      // Note: localhost http may still be blocked by X-Frame-Options
      var embedUrl = 'https://player.bilibili.com/player.html?isOutside=true&bvid=' + encodeURIComponent(bvid) + '&autoplay=1&danmaku=0&high_quality=1';
      
      iframe.src = embedUrl;
      m.classList.add('active');
      document.body.style.overflow = 'hidden';

      // Detect iframe load failure (X-Frame-Options block) after 3s
      // If iframe is blocked, automatically fall back to direct navigation
      setTimeout(function() {
        try {
          // Try to access iframe content - if blocked by X-Frame-Options, this will throw error
          var doc = iframe.contentDocument || iframe.contentWindow.document;
          // If we can access it, iframe loaded successfully
          console.log('[content-patcher] ✅ Video iframe loaded successfully:', bvid);
        } catch(e) {
          // CORS/X-Frame-Options error - iframe blocked, fallback to direct navigation
          console.log('[content-patcher] ⚠️  Video iframe blocked by X-Frame-Options, falling back to direct navigation:', bvid);
          
          // Close modal and navigate directly to B站
          closeVideoModal();
          
          // Direct navigation to B站 embed page with autoplay
          var directUrl = 'https://www.bilibili.com/player/web_api/v2/player?aid=&bvid=' + encodeURIComponent(bvid) + '&cid=&page=1&autoplay=1';
          console.log('[content-patcher] 🔗 Redirecting to:', directUrl);
          window.location.href = directUrl;
        }
      }, 3000);
    } else {
      // Fallback: direct navigation to B站 embed player
      var embedUrl = 'https://player.bilibili.com/player.html?isOutside=true&bvid=' + encodeURIComponent(bvid) + '&autoplay=1&danmaku=0&high_quality=1';
      window.location.href = embedUrl;
    }
  }

  function closeVideoModal() {
    var m = document.getElementById('kpr-v-modal');
    var iframe = document.getElementById('kpr-v-iframe');
    if (!m || !iframe) return;
    iframe.src = '';
    m.classList.remove('active');
    document.body.style.overflow = '';
  }

  // ── Gallery Hover Pause ──
  // Pause carousel when mouse hovers over the gallery area.
  // Works by intercepting gsap.delayedCall — when paused, the next scheduled
  // loopCards callback is killed and re-scheduled with a long delay.
  // On mouse leave, the original carouselInterval is restored.
  var _carouselPaused = false;
  var _carouselInterval = (config && config.gallery && config.gallery.carouselInterval) || 8;

  function setupGalleryHoverPause() {
    var trySetup = 0;
    function attempt() {
      var gallery = document.querySelector('.collectionGallery') || document.getElementById('collection-gallery');
      if (!gallery && trySetup < 15) {
        trySetup++;
        setTimeout(attempt, 1000);
        return;
      }
      if (!gallery) return;

      // Intercept gsap.delayedCall to support pausing
      if (typeof window !== 'undefined' && window.gsap) {
        var _origDelayedCall = window.gsap.delayedCall;
        window.gsap.delayedCall = function(dur, fn, params) {
          if (_carouselPaused && fn && fn.toString().indexOf('loopCards') !== -1) {
            // Return a dummy tween that won't fire for a very long time
            return _origDelayedCall.call(window.gsap, 99999, fn, params);
          }
          return _origDelayedCall.call(window.gsap, dur, fn, params);
        };
      }

      // Mouse enter → pause carousel
      gallery.addEventListener('mouseenter', function() {
        _carouselPaused = true;
        console.log('[content-patcher] ⏸ Gallery hover — carousel paused');
      });

      // Mouse leave → resume carousel
      gallery.addEventListener('mouseleave', function() {
        _carouselPaused = false;
        console.log('[content-patcher] ▶ Gallery hover end — carousel resumed');
      });

      console.log('[content-patcher] ✅ Gallery hover pause set up');
    }
    attempt();
  }

  // Document-level video click handler - THIRD LAYER PROTECTION (highest priority)
  // This catches clicks anywhere in document and checks if they're on video items
  function setupDocumentLevelVideoHandler() {
    document.addEventListener('click', function(e) {
      // Check if click is inside any video item
      var videoItems = document.querySelectorAll('[data-kpr-video-item]');
      for (var i = 0; i < videoItems.length; i++) {
        if (videoItems[i].contains(e.target)) {
          // Find the video config for this item
          var itemIndex = parseInt(videoItems[i].getAttribute('data-kpr-video-index') || '0');
          var galleryCfg = config && config.gallery;
          var videos = (galleryCfg && galleryCfg.videos) || [];
          if (videos[itemIndex]) {
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
            console.log('[content-patcher] 🎬 Video clicked (layer 3 - document):', videos[itemIndex].bvid);
            openVideoModal(videos[itemIndex].bvid, videos[itemIndex].label || 'Video');
            return; // Prevent further processing
          }
        }
      }
    }, true); // capture mode - highest priority
  }
  
  // Kick off gallery video preview (if configured)
  if (config && config.gallery && config.gallery.videos && config.gallery.videos.length > 0) {
    setupGalleryVideoPreview();
  }
  
  // Setup document-level handler after a delay to ensure DOM is ready
  setTimeout(setupDocumentLevelVideoHandler, 3000);

  // Kick off gallery hover pause
  setupGalleryHoverPause();

})();
